@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Master>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor _httpContextAccessor;
@{
	Layout = null;

    var pageTitle = !string.IsNullOrWhiteSpace(Model.PageTitle) ? Model.PageTitle : Model.Name;
    var homePage = Model.AncestorOrSelf<HomePage>();
    
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var urlRequest = _httpContextAccessor.HttpContext.Request;
    var domain = urlRequest.Host.Value;
    var baseUrl = urlRequest.Scheme + "://" + domain;
    var canonicalUrl = Model.Url(culture: currentCulture, mode: UrlMode.Absolute);
    if (string.IsNullOrWhiteSpace(canonicalUrl))
    {
        canonicalUrl = baseUrl + urlRequest.Path + urlRequest.QueryString;
    }
    
    Umbraco.Cms.Core.Models.MediaWithCrops metaImage = Model.MetaImage;
    if(metaImage == null)
    {
        metaImage = homePage.MetaImage;
    }

    string metaDescription = Model.MetaDescription;
    if(string.IsNullOrWhiteSpace(metaDescription))
    {
        metaDescription = homePage.MetaDescription;
    }
}

<!doctype html>
<html class="no-js" lang="@currentCulture">
    <head>
        <title>Promomark | @pageTitle</title>
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="author" content="Demax">
        <meta name="viewport" content="width=device-width,initial-scale=1.0" />
        <meta name="description" content="@metaDescription">
        <link rel="canonical" href="@canonicalUrl" />
        @if(Model.Cultures?.Any() == true)
        {
            foreach (var culture in Model.Cultures)
            {
                var cultureUrl = Model.Url(culture.Key, UrlMode.Absolute);
                if(!string.IsNullOrWhiteSpace(cultureUrl))
                {
                    <link rel="alternate" hreflang="@culture.Value.Culture" href="@cultureUrl" />
                }
            }
            <link rel="alternate" hreflang="x-default" href="@canonicalUrl" />
        }
        @if(metaImage != null)
        {
            <meta property="og:image" content="@metaImage.GetCropUrl(1200, 628, urlMode: UrlMode.Absolute)">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="628">
        } 
        <!-- favicon icon -->

        <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png?" asp-append-version="true" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg?" asp-append-version="true" />
        <link rel="shortcut icon" href="/favicon/favicon.ico" asp-append-version="true" />
        <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png?" asp-append-version="true" />
        <meta name="apple-mobile-web-app-title" content="Promomark" />
        <link rel="manifest" href="/favicon/site.webmanifest" asp-append-version="true" />

        <!-- google fonts preconnect -->
        <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Urbanist:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

        <script type="application/ld+json">
            {
                "@@context": "https://schema.org",
                "@@type": "WebSite",
                "url": "@baseUrl",
                "name": "Promomark",
                "description": "@metaDescription",
                "publisher": {
                    "@@type": "Organization",
                    "name": "Promomark",
                    "logo": {
                    "@@type": "ImageObject",
                    "url": "@baseUrl/images/logo/promomark-logo.svg"
                    }
                }
            }
        </script>
        <script type="application/ld+json">
            {
                "@@context": "https://schema.org",
                "@@type": "Organization",
                "url": "@baseUrl",
                "name": "Promomark",
                "legalName": "Promomark d.o.o.",
                "description": "@metaDescription",
                "logo": {
                    "@@type": "ImageObject",
                    "url": "@baseUrl/images/logo/promomark-logo.svg"
                }
            }
        </script>
        
        <!-- Preload the main script for better performance -->
        <link rel="preload" href="~/scripts/site.min.js" as="script" asp-append-version="true">
        
        <link rel="stylesheet" href="~/css/site.min.css?" asp-append-version="true"/>
    </head>
   <body data-mobile-nav-style="classic">
        
        @await Html.PartialAsync("Header")
        @RenderBody()
        @await Html.PartialAsync("Footer")
        
        <!-- start cookie message -->
        <div id="cookies-model" class="cookie-message bg-dark-gray border-radius-8px"> 
            <div class="cookie-description fs-14 mb-20px lh-22 text-white">We use cookies to enhance your browsing experience, serve personalized ads or content, and analyze our traffic. By clicking "Allow cookies" you consent to our use of cookies. </div>   
            <div class="cookie-btn">
                <a href="#" class="btn btn-transparent-white border-1 border-color-transparent-white-light btn-very-small btn-switch-text btn-rounded w-100 mb-15px" aria-label="btn">
                    <span>
                        <span class="btn-double-text" data-text="Cookie policy">Cookie policy</span> 
                    </span>
                </a> 
                <a href="#" class="btn btn-white btn-very-small btn-switch-text btn-box-shadow accept_cookies_btn btn-rounded w-100" data-accept-btn aria-label="text">
                    <span>
                        <span class="btn-double-text" data-text="Allow cookies">Allow cookies</span> 
                    </span>
                </a>
            </div> 
        </div>
        <!-- end cookie message -->
        <!-- start scroll progress -->
        <div class="scroll-progress d-none d-xxl-block">
            <a href="#" class="scroll-top" aria-label="scroll">
                <span class="scroll-text">Scroll</span><span class="scroll-line"><span class="scroll-point"></span></span>
            </a>
        </div>
        <!-- end scroll progress -->

        <!-- javascript libraries -->
			
        <script type="text/javascript" src="~/scripts/site.min.js" asp-append-version="true" defer></script>
    </body>
</html>